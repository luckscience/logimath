---
import Logo from "../components/Logo.astro";

type Segment = {
  text: string;
  route?: string;
  color?: string;
  fontSize?: string;
  fontWeight?: string;
  class?: string;
};

const {
  segments = [],
  rightSegments = [],
  class: className = "",
} = Astro.props;
---

<header
  id="landing-header"
  class={`py-3 px-10 flex items-center fixed top-0 w-full h-20 justify-between z-40 
  bg-background/95 backdrop-blur-md border-b border-blue-950 ${className}`}
>
  <!-- LOGO -->
  <div class="flex grow basis-0 ml-20 gap-4 items-center">
    <a href="/#home"><Logo /></a>
    <h1 class="font-heading font-bold text-[20px] text-white">
      <span class="text-[#F4E13A]">Logi</span>Math
    </h1>
  </div>

  <!-- NAV CENTRAL DINÁMICO -->
  <nav>
    <ul class="flex -ml-20 font-body">
      {segments.map((item: Segment) => (
        <li>
          <a
            href={item.route || "#"}
            class={`relative group px-4 py-2 inline-block ${item.class || ""}`}
            style={`
              color: ${item.color || "white"};
              font-size: ${item.fontSize || "17px"};
              font-weight: ${item.fontWeight || "500"};
            `}
          >
            {item.text}
            <span
              class="absolute left-1/2 bottom-0 w-0 h-0.5 bg-current transition-all duration-300 group-hover:w-full group-hover:left-0"
            ></span>
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- NAV DERECHA DINÁMICO -->
  <nav class="flex grow justify-end basis-0">
    <ul class="flex text-sm">
      {rightSegments.map((item: Segment) => (
        <li>
          <a
            href={item.route || "#"}
            class={`px-4 py-2 rounded-[5px] inline-block ${item.class || ""}`}
            style={`
              color: ${item.color || "white"};
              font-size: ${item.fontSize || "17px"};
              font-weight: ${item.fontWeight || "500"};
            `}
          >
            {item.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>