---
import Layout from "../layouts/Layout.astro";
import Header from "../layouts/Header.astro";
import Footer from "../layouts/Footer.astro";
import MathSymbols from "../components/MathSymbols.astro";
import Divider from "../components/Divider.astro";
---

<Layout>
  <Header />

  <main
    class="relative w-full h-screen overflow-y-auto overflow-x-hidden scroll-smooth bg-[#070F33] select-none"
  >
    <div class="snap-center">
      <section
        class="h-screen w-screen flex items-center justify-center grid-pattern bg-center relative overflow-hidden"
      >
        <div class="absolute inset-0 z-20 backdrop-blur-xs"></div>

        <div class="absolute inset-0 z-10">
          <MathSymbols />
        </div>

        <div
          class="relative z-20 w-full flex items-center justify-center mt-20"
        >
          <form
            id="login-form"
            class="w-105 p-13 rounded-2xl border border-white/10 bg-white/10 backdrop-blur-2xl shadow-[0_0_30px_20px_rgba(0,0,0,0.1)] text-white flex flex-col items-center"
          >
            <h1 class="mb-4 text-2xl font-semibold">Iniciar Sesión</h1>

            <!-- Email -->
            <div class="w-full relative mt-5">
              <input
                type="email"
                name="email"
                placeholder="Correo electrónico"
                required
                class="w-full pl-10 pr-4 py-2 rounded-xl bg-white/10 border-2 border-transparent text-white placeholder-white/70 outline-none focus:border-white/25 caret-white font-medium transition-all duration-300"
              />
              <i
                class="user-icon absolute left-3 top-1/2 -translate-y-1/2 text-white/70 text-lg transition-all duration-300"
              ></i>
            </div>

            <!-- Password -->
            <div class="w-full relative mt-5">
              <input
                type="password"
                name="password"
                required
                placeholder="Contraseña"
                class="w-full pl-10 pr-4 py-2 rounded-xl bg-white/10 border-2 border-transparent text-white placeholder-white/70 outline-none focus:border-white/25 caret-white font-medium transition-all duration-300"
              />
              <i
                class="bx bxs-lock-alt absolute left-3 top-1/2 -translate-y-1/2 text-white/70 text-lg transition-all duration-300"
              ></i>
            </div>

            <!-- Remember / Forgot -->
            <div class="w-full flex justify-between mt-4 text-sm">
              <div class="flex items-center gap-2">
                <input
                  type="checkbox"
                  id="remember-me"
                  onclick="console.log(this.checked)"
                  class="accent-cyan-400"
                />
                <label for="remember-me">Mantener sesión activa</label>
              </div>

              <a href="#" class="hover:underline">Forgot password</a>
            </div>

            <div class="w-full flex justify-center mt-4">
              <div
                class="flex-col text-center items-center justify-center text-gray-foreground p-4"
              >
                <div class="flex flex-row font-bold">
                  <Divider />
                  <span class="mx-2 -mt-3">o</span>
                  <Divider />
                </div>
                <button
                  type="button"
                  id="google-login"
                  class="w-full mt-4 py-2 rounded-xl border border-white/20 bg-white/5 hover:bg-white/10 transition-all duration-300"
                >
                  <i class="fa-brands fa-google mr-1"></i>
                  Continuar con Google
                </button>
              </div>
            </div>

            <!-- Button -->
            <button
              type="submit"
              class="w-full mt-10 py-2 rounded-xl bg-[#2769b4] font-bold text-sm hover:opacity-80 focus:outline-none focus:ring-4 focus:ring-[#32CDD58A] transition-all duration-300"
            >
              Ingresar
            </button>

            <!-- Register -->
            <p class="mt-8 text-sm">
              ¿No tienes una cuenta?
              <a href="/register" class="font-bold ml-2">Registrarse</a>
            </p>
          </form>
        </div>
      </section>
    </div>
  </main>

  <div class="snap-start">
    <Footer />
  </div>
</Layout>

<script src="../scripts/login.ts"></script>
