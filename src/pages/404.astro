---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div class="flex min-h-screen items-center justify-center bg-[#0e1638] scroll-smooth grid-pattern">
    <div class="absolute inset-0 z-20 backdrop-blur-[2px]"></div>
    <div class="text-center z-20">
      <h2 class="text-3xl -mb-15 font-heading font bold text-blue-300">ERROR</h2>
      <h1 class="mb-4 text-[220px] font-heading font-bold text-red-200">404</h1>
      <p class="mb-4 -mt-15 text-xl text-gray-foreground">Lo sentimos, la página a la que intentas acceder no existe o no es accesible.</p>
      <p class="mb-8 text-xl text-gray-foreground">Por favor, verifica la URL o regresa a la página principal.</p>
      <a
              href="/#home"
              class="inline-block px-8 py-4 bg-[#F4E13A] text-black font-heading font-bold rounded border-2 border-[#F4E13A] hover:bg-transparent hover:text-[#F4E13A] transition-all duration-300"
              >← Regresar a la página principal</a
            >
    </div>
  </div>
</Layout>
