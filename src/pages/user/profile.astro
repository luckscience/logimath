---
import Layout from "../../layouts/Layout.astro";
import Header from "../../layouts/Header.astro";
import Footer from "../../layouts/Footer.astro";
import { supabase } from "../../lib/supabase";

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login");
}

const { data, error } = await supabase
  .from("profiles")
  .select("*")
  .eq("id", user.id)
  .single();

const defaultAvatar = "/default-avatar.webp";
---

<Layout>
  <div class="min-h-screen flex flex-col bg-[#070F33] grid-pattern">
    <Header />

    <main class="flex-1 w-full overflow-x-hidden scroll-custom select-none">
      <div class="max-w-371.25 mx-auto px-5 pt-28 pb-16">
        <!-- PROFILE HEADER -->
        <section
          class="bg-[#0e1638] border border-white/10 rounded-3xl p-6 md:p-8 text-white shadow-2xl"
        >
          <div class="flex flex-col lg:flex-row lg:items-center gap-8">
            <!-- AVATAR -->
            <div class="flex flex-col items-center">
              <img
                src={data.avatar_url || defaultAvatar}
                alt="User avatar"
                class="w-36 h-36 rounded-full object-cover border-4 border-cyan-400 shadow-lg"
              />

              <button
                class="mt-4 px-4 py-2 text-sm rounded-xl bg-cyan-500 hover:bg-cyan-400 transition font-medium"
              >
                Cambiar foto
              </button>
            </div>

            <!-- USER INFO -->
            <div class="flex-1">
              <div
                class="flex flex-col md:flex-row md:items-center md:justify-between gap-4"
              >
                <div>
                  <h1 class="text-3xl font-bold">
                    {data.username}
                  </h1>

                  <p class="text-cyan-300 mt-1">
                    {data.username}
                  </p>

                  <p class="text-sm text-gray-400 mt-2">
                    {user.role}
                  </p>
                </div>

                <div class="flex gap-3">
                  <button
                    id="open-edit-modal"
                    class="px-5 py-2 rounded-xl bg-cyan-500 hover:bg-cyan-400 transition font-medium"
                  >
                    Editar perfil
                  </button>

                  <button
                    class="px-5 py-2 rounded-xl border border-white/20 hover:bg-white/10 transition"
                  >
                    Compartir
                  </button>
                </div>
              </div>

              <!-- BIO -->
              <div class="mt-6">
                <h2 class="text-lg font-semibold mb-2">Sobre mí:</h2>

                <p class="text-gray-300 leading-relaxed">
                  {data.bio}
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- GRID CONTENT -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-6">
          <!-- LEFT COLUMN -->
          <div class="lg:col-span-1 space-y-6">
            <!-- CONTACT CARD -->
            <section
              class="bg-[#0e1638] border border-white/10 rounded-3xl p-6 text-white"
            >
              <h3 class="text-xl font-semibold mb-5">
                Información de contacto
              </h3>

              <div class="space-y-4 text-sm">
                <div>
                  <p class="text-gray-400">Correo</p>
                  <p>{user.email}</p>
                </div>

                <div>
                  <p class="text-gray-400">Teléfono</p>
                  <p>{user.phone}</p>
                </div>

                <div>
                  <p class="text-gray-400">Ubicación</p>
                  <p>MX</p>
                </div>
              </div>
            </section>

            <!-- SKILLS -->
            <section
              class="bg-[#0e1638] border border-white/10 rounded-3xl p-6 text-white"
            >
              <h3 class="text-xl font-semibold mb-5">Habilidades</h3>

              <div class="flex flex-wrap gap-3">
                <span
                  class="px-3 py-1 rounded-full bg-cyan-500/20 text-cyan-300 text-sm"
                >
                  Astro
                </span>

                <span
                  class="px-3 py-1 rounded-full bg-cyan-500/20 text-cyan-300 text-sm"
                >
                  TailwindCSS
                </span>

                <span
                  class="px-3 py-1 rounded-full bg-cyan-500/20 text-cyan-300 text-sm"
                >
                  TypeScript
                </span>

                <span
                  class="px-3 py-1 rounded-full bg-cyan-500/20 text-cyan-300 text-sm"
                >
                  UI Design
                </span>
              </div>
            </section>
          </div>

          <!-- RIGHT COLUMN -->
          <div class="lg:col-span-2 space-y-6">
            <!-- ACTIVITY -->
            <section
              class="bg-[#0e1638] border border-white/10 rounded-3xl p-6 text-white"
            >
              <div class="flex items-center justify-between mb-6">
                <h3 class="text-xl font-semibold">Actividad reciente</h3>

                <button class="text-sm text-cyan-300 hover:text-cyan-200">
                  Ver todo
                </button>
              </div>

              <div class="space-y-4">
                <div class="p-4 rounded-2xl bg-white/5 border border-white/5">
                  <p class="font-medium">Actualizaste tu perfil</p>

                  <span class="text-sm text-gray-400"> Hace 2 horas </span>
                </div>

                <div class="p-4 rounded-2xl bg-white/5 border border-white/5">
                  <p class="font-medium">Publicaste un nuevo proyecto</p>

                  <span class="text-sm text-gray-400"> Ayer </span>
                </div>

                <div class="p-4 rounded-2xl bg-white/5 border border-white/5">
                  <p class="font-medium">Cambiaste tu foto de perfil</p>

                  <span class="text-sm text-gray-400"> Hace 3 días </span>
                </div>
              </div>
            </section>

            <!-- SETTINGS -->
            <section
              class="bg-[#0e1638] border border-white/10 rounded-3xl p-6 text-white"
            >
              <h3 class="text-xl font-semibold mb-6">Configuración rápida</h3>

              <div class="grid md:grid-cols-2 gap-4">
                <button
                  class="p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition text-left border border-white/5"
                >
                  <p class="font-medium">Seguridad</p>

                  <span class="text-sm text-gray-400">
                    Cambiar contraseña y autenticación
                  </span>
                </button>

                <button
                  class="p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition text-left border border-white/5"
                >
                  <p class="font-medium">Notificaciones</p>

                  <span class="text-sm text-gray-400">
                    Configura alertas y correos
                  </span>
                </button>

                <button
                  class="p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition text-left border border-white/5"
                >
                  <p class="font-medium">Apariencia</p>

                  <span class="text-sm text-gray-400">
                    Personaliza el tema visual
                  </span>
                </button>

                <button
                  class="p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition text-left border border-white/5"
                >
                  <p class="font-medium">Privacidad</p>

                  <span class="text-sm text-gray-400">
                    Controla tu información pública
                  </span>
                </button>

                <button
                  id="logout-btn"
                  class="p-3 rounded-2xl bg-red-500 hover:bg-red-400 transition font-bold"
                  >🔒 Cerrar Sesión</button
                >
              </div>
            </section>
          </div>
        </div>
      </div>
    </main>

    <!-- EDIT PROFILE MODAL -->
    <div
      id="edit-modal"
      class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300"
    >
      <!-- OVERLAY -->
      <div
        id="modal-overlay"
        class="absolute inset-0 bg-black/70 backdrop-blur-sm"
      >
      </div>

      <!-- MODAL CONTENT -->
      <div
        id="modal-content"
        class="relative z-10 w-full max-w-lg mx-4 bg-[#0e1638] border border-white/10 rounded-3xl p-6 text-white shadow-2xl scale-95 opacity-0 transition-all duration-300"
      >
        <h2 class="text-2xl font-bold mb-6">Editar perfil</h2>

        <form class="space-y-5">
          <!-- USERNAME -->
          <div>
            <label class="block text-sm text-gray-300 mb-2">
              Nombre de usuario
            </label>

            <input
              type="text"
              id="username-input"
              value={data.username}
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 focus:outline-none focus:border-cyan-400"
            />
          </div>

          <!-- BIO -->
          <div>
            <label class="block text-sm text-gray-300 mb-2"> Biografía </label>

            <textarea
              rows="4"
              id="bio-input"
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 focus:outline-none focus:border-cyan-400"
              >{data.bio}</textarea
            >
          </div>

          <!-- BUTTONS -->
          <div class="flex justify-end gap-3 pt-4">
            <button
              type="button"
              id="close-edit-modal"
              class="px-5 py-2 rounded-xl border border-white/20 hover:bg-white/10 transition"
            >
              Cancelar
            </button>

            <button
              type="submit"
              id="save-changes-btn"
              class="px-5 py-2 rounded-xl bg-cyan-500 hover:bg-cyan-400 transition font-medium"
            >
              Guardar cambios
            </button>
          </div>
        </form>
      </div>
    </div>

    <Footer />
  </div>

  <script src="../../scripts/logout.ts"></script>
  <script src="../../scripts//editProfile.ts"></script>
</Layout>
