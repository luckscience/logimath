---
import Layout from "../layouts/Layout.astro";
import Header from "../layouts/Header.astro";
import Footer from "../layouts/Footer.astro";
import MainSection from "../components/exercises/MainSection.astro"
---

<Layout>
  <Header
    segments={[
      {
        text: "Inicio",
        route: "/#home",
      },
    ]}
    rightSegments={[
      {
        text: "Iniciar sesión",
        route: "/login",
        class:
          "font-bold text-white px-15 mr-6 hover:text-blue-300 transition-all duration-300",
      },
    ]}
  />

  <main
    class="relative w-full h-screen overflow-y-auto overflow-x-hidden scroll-custom bg-[#070F33] select-none"
  >
    <div class="snap-y snap-mandatory h-full overflow-y-auto scroll-smooth">
      <div class="snap-center">
        <MainSection />
      </div>
      <div class="snap-start">
        <Footer />
      </div>
    </div>
  </main>
</Layout>
